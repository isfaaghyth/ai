# isfa-ai — Central Configuration
# Single entrypoint for all agent config. Fill this in, then run ./setup.sh.

# Provider (applies to all agents)
# Change PROVIDER to "anthropic" and PROVIDER_BASE_URL to "https://api.anthropic.com/v1"
# to bypass OpenRouter and hit Anthropic directly.
PROVIDER=openrouter
PROVIDER_BASE_URL=https://openrouter.ai/api/v1

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub — PAT scopes needed: repo, workflow, read:org
# Generate at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=your_github_personal_access_token_here
GIT_AUTHOR_NAME=Isfa
GIT_AUTHOR_EMAIL=your_email@example.com
SSH_KEY_PATH=~/.ssh

# Workspace — parent folder for all project repos, mounted at /opt/workspace
WORKSPACE_ROOT=/Users/isfa/projects

# Global agent limits (applies to all profiles unless overridden)
AGENT_MAX_TURNS=90
AGENT_TIMEOUT=180

# Default model — fallback used by any agent whose MODEL_* var is left unset.
# Useful for quick local testing without configuring every profile.
# Common OpenRouter IDs: anthropic/claude-sonnet-5, google/gemini-3.5-flash, z-ai/glm-5.2
DEFAULT_MODEL=anthropic/claude-sonnet-5
DEFAULT_REASONING=medium

# Dev — Technical Product Manager (orchestrates all dev agents)
MODEL_DEV_TPM=anthropic/claude-opus-4.6
REASONING_DEV_TPM=high

# Dev — Kotlin Multiplatform Mobile Engineer
MODEL_DEV_KOTLIN_MOBILE_PLANNING=anthropic/claude-opus-4.6
MODEL_DEV_KOTLIN_MOBILE_EXECUTION=anthropic/claude-sonnet-5
REASONING_DEV_KOTLIN_MOBILE=high

# Dev — Golang Backend Engineer
MODEL_DEV_GOLANG_BACKEND_PLANNING=z-ai/glm-5.2
MODEL_DEV_GOLANG_BACKEND_EXECUTION=qwen/qwen-3-coder-480b-a35b-instruct
REASONING_DEV_GOLANG_BACKEND=high

# Dev — React + Tailwind Frontend Engineer
MODEL_DEV_FRONTEND_REACT_PLANNING=z-ai/glm-5.2
MODEL_DEV_FRONTEND_REACT_EXECUTION=anthropic/claude-sonnet-5
REASONING_DEV_FRONTEND_REACT=high

# Daily — General Assistant
MODEL_DAILY_GENERAL=google/gemini-3.5-flash
REASONING_DAILY_GENERAL=medium

# Daily — Learning Buddy
MODEL_DAILY_LEARNING_BUDDY=google/gemini-3.5-flash
REASONING_DAILY_LEARNING_BUDDY=high

# Telegram — create 6 bots via @BotFather, get your user ID from @userinfobot
TELEGRAM_TOKEN_DEV_TPM=your_tpm_agent_bot_token_here
TELEGRAM_TOKEN_DEV_KOTLIN_MOBILE=your_kotlin_agent_bot_token_here
TELEGRAM_TOKEN_DEV_GOLANG_BACKEND=your_golang_agent_bot_token_here
TELEGRAM_TOKEN_DEV_FRONTEND_REACT=your_frontend_agent_bot_token_here
TELEGRAM_TOKEN_DAILY_GENERAL=your_general_agent_bot_token_here
TELEGRAM_TOKEN_DAILY_LEARNING_BUDDY=your_learning_buddy_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=your_numeric_telegram_user_id_here
