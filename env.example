# =========================================================================
# CENTRAL ENVIRONMENT CONFIGURATION
# Copy this file to `.env` and fill in your keys.
# WORKSPACE_ROOT: The parent directory containing all your projects.
# On Mac (local): /Users/isfa/projects
# On VPS (Linux): /home/isfa/projects (or wherever you clone your repos)
# Then run `./setup.sh` to propagate configs to all agent profiles.
# =========================================================================

# Central API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Workspace Root - parent folder that contains all your project repos
# All agents will see this folder mounted at /opt/workspace inside the container
WORKSPACE_ROOT=/Users/isfa/projects

# Telegram Bot Tokens (Create 6 separate bots via @BotFather on Telegram)
TELEGRAM_TOKEN_DEV_TPM=your_tpm_agent_bot_token_here
TELEGRAM_TOKEN_DEV_KOTLIN_MOBILE=your_kotlin_agent_bot_token_here
TELEGRAM_TOKEN_DEV_GOLANG_BACKEND=your_golang_agent_bot_token_here
TELEGRAM_TOKEN_DEV_FRONTEND_REACT=your_frontend_agent_bot_token_here
TELEGRAM_TOKEN_DAILY_GENERAL=your_general_agent_bot_token_here
TELEGRAM_TOKEN_DAILY_LEARNING_BUDDY=your_learning_buddy_bot_token_here

# Restrict Access (CRITICAL: Fill in your Telegram User ID so others can't control your agent)
# Send a message to @userinfobot on Telegram to retrieve your numeric ID.
TELEGRAM_ALLOWED_USER_IDS=your_numeric_telegram_user_id_here
